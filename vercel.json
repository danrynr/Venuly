{
  "version": 2,
  "builds": [
    {
      "src": "src/app.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/app.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/process-expirations",
      "schedule": "* * * * *"
    }
  ]
}
