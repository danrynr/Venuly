{
  "version": 2,
  "functions": {
    "app.ts": {
      "includeFiles": "swagger.yaml"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/app.ts"
    },
    {
      "source": "/docs",
      "destination": "/app.ts"
    },
    {
      "source": "/docs/swagger.json",
      "destination": "/app.ts"
    }
  ]
}