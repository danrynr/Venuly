{
  "version": 2,
  "functions": {
    "api/app.js": {
      "includeFiles": "swagger.yaml"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/app.js"
    },
    {
      "source": "/docs",
      "destination": "/api/app.js"
    },
    {
      "source": "/docs/swagger.json",
      "destination": "/api/app.js"
    }
  ]
}